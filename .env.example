DATABASE_URL=postgresql+psycopg2://ipam_user:ipam_pass@localhost:5432/ipam
APP_TITLE=IPAM FastAPI

# Omnissa OIDC
OIDC_DISCOVERY_URL=https://<omnissa-host>/.well-known/openid-configuration
OIDC_CLIENT_ID=<client_id>
OIDC_CLIENT_SECRET=<client_secret>
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback
OIDC_SCOPES=openid profile email
OIDC_AUDIENCE=<client_id>

SESSION_SECRET=change_me_long_random_value

DC_PREFIX=100.121.
DR_PREFIX=100.112.

ADMIN_GROUP=IPAM-Admins

# Local Authentication (optional)
LOCAL_ADMIN_USERNAME=admin
LOCAL_ADMIN_PASSWORD=admin123
LOCAL_ADMIN_EMAIL=admin@example.com
